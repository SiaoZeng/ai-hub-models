# Replaces torch.cartesian_prod with meshgrid and removes einsum for export compatibility.
#
diff --git a/src/depth_anything_3/cfg.py b/src/depth_anything_3/cfg.py
index 4607ff8..7c5c34b 100644
--- a/src/depth_anything_3/cfg.py
+++ b/src/depth_anything_3/cfg.py
@@ -102,6 +102,8 @@ def import_item(path: str, name: str) -> Any:
     """
     Import a python item. Example: import_item("path.to.file", "MyClass") -> MyClass
     """
+    if path.startswith("depth_anything_3"):
+        path = __package__.rsplit(".", 1)[0] + "." + path
     return getattr(importlib.import_module(path), name)
 
 
diff --git a/src/depth_anything_3/model/dinov2/layers/rope.py b/src/depth_anything_3/model/dinov2/layers/rope.py
