-        return up_flow.reshape(N, 2, rate*H, rate*W)
+        Uses a conv2d-based gather instead of the original 7D/6D-reshape
+        approach for better export compatibility.
+        """
+        N, _, H, W = flow.shape
+        mask = (
+            mask.permute(0, 2, 3, 1).view(N, H * W, 9, rate * rate).permute(0, 1, 3, 2)
+        )  # [N, H*W, rate*rate, 9]
+        mask = torch.softmax(mask, dim=-1)
+        # Gather the 9-neighbourhood for every flow pixel via conv2d
+        up_flow = (
+            F.conv2d(
+                (rate * flow).view(N * 2, 1, H, W),
+                self._unfold_kernel,
+                padding=1,
+            )
+            .permute(0, 2, 3, 1)
+            .view(N * 2, H * W, 1, 9)
+        )
+        # Weighted sum over neighbours
+        up_flow = (mask * up_flow).sum(dim=-1)  # broadcast N*2 over N
+        # Fold back to spatial layout
+        up_flow = up_flow.reshape(N * 2, H, W, rate, rate).permute(0, 1, 3, 2, 4)
+        return up_flow.reshape(N, 2, rate * H, rate * W)
 
     def zero_init(self, fmap):
         N, C, H, W = fmap.shape
