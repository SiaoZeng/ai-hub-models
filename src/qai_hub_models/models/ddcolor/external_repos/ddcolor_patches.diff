 def build_network(opt):
diff --git a/basicsr/archs/ddcolor_arch_utils/unet.py b/basicsr/archs/ddcolor_arch_utils/unet.py
index 4610ba5..cc65aaf 100644
--- a/basicsr/archs/ddcolor_arch_utils/unet.py
+++ b/basicsr/archs/ddcolor_arch_utils/unet.py
@@ -166,7 +166,7 @@ class CustomPixelShuffle_ICNR(nn.Module):
         self.conv = custom_conv_layer(
             ni, nf * (scale**2), ks=1, use_activ=False, norm_type=norm_type, extra_bn=extra_bn)
         icnr(self.conv[0].weight)
-        self.shuf = nn.PixelShuffle(scale)
+        self.scale = scale
         self.do_blur = blur
         # Blurring over (h*w) kernel
         # "Super-Resolution using Convolutional Neural Networks without Any Checkerboard Artifacts"
@@ -176,7 +176,8 @@ class CustomPixelShuffle_ICNR(nn.Module):
         self.relu = nn.ReLU(True)
 
     def forward(self, x):
-        x = self.shuf(self.relu(self.conv(x)))
+        x = self.relu(self.conv(x))
+        x = x.reshape(-1, self.scale, self.scale, x.shape[2], x.shape[3]).permute(0, 3, 1, 4, 2).reshape(x.shape[0], -1, x.shape[2] * self.scale, x.shape[3] * self.scale)
         return self.blur(self.pad(x)) if self.do_blur else x
 
 
